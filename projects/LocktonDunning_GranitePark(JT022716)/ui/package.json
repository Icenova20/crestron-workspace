{
  "name": "rangerstr-html-control",
  "version": "1.0.0",
  "description": "Crestron HTML5 UI for Rangers Training Room",
  "main": "index.html",
  "scripts": {
    "start": "echo 'Open index.html in a browser or load onto processor'",
    "build:archive": "node ./node_modules/@crestron/ch5-utilities-cli/build/index.js archive -p lockton_dunning -d . -o ./",
    "build": "npm run build:archive"
  },
  "devDependencies": {
    "@crestron/ch5-utilities-cli": "^2.0.0"
  },
  "dependencies": {
    "@crestron/ch5-crcomlib": "^2.0.0",
    "@crestron/ch5-webxpanel": "^2.0.0"
  }
}